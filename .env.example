# Sandbox Service — client testing config
#
# Copy to `.env` and fill in your values. `chmod 0600 .env` after,
# since it holds the API bearer token.
#
#   cp .env.example .env
#   chmod 0600 .env
#   $EDITOR .env
#
# Used by tools/smoke-remote.sh and ad-hoc test scripts. The actual
# service-side config lives in /etc/sandbox/env on the Linux host
# (see docs/SETUP.md).


# ----- Where the sandbox API is running -----

# The Linux host's IP or hostname. Examples:
#   SANDBOX_HOST=16.3.20.1
#   SANDBOX_HOST=sandbox.internal.example.com
SANDBOX_HOST=

# The port the API is bound to on the Linux host. In production the
# API is bound to 127.0.0.1 (SPEC-302), so you reach it via SSH tunnel.
SANDBOX_PORT=8000


# ----- SSH tunnel (recommended over direct LAN) -----

# Host to tunnel through. Usually the same as SANDBOX_HOST.
SSH_HOST=

# Username on the Linux host with sudo / docker-group access.
SSH_USER=

# Path to your private key. Use SSH key auth, NEVER passwords —
# password-based SSH automation is fragile and a known anti-pattern.
# If you don't have a key set up:
#   ssh-keygen -t ed25519 && ssh-copy-id $SSH_USER@$SSH_HOST
SSH_KEY=~/.ssh/id_ed25519

# Local port the tunnel binds on your client machine.
# Tests hit http://127.0.0.1:$TUNNEL_LOCAL_PORT.
TUNNEL_LOCAL_PORT=8000


# ----- Remote repo layout (used by tools/smoke-remote.sh) -----

# Absolute path to the cloned repo on the Linux host. The smoke-test
# script invokes `$REMOTE_REPO_PATH/.venv/bin/uvicorn` from there, so
# `uv sync` must already have been run on the remote.
REMOTE_REPO_PATH=/opt/sandbox


# ----- Auth -----

# Bearer token. Must match the SANDBOX_API_TOKEN value in
# /etc/sandbox/env on the Linux host (or in the env you used when
# launching uvicorn directly).
#
# Generate with: openssl rand -hex 32
#
# NOTE: tools/smoke-remote.sh ignores this and generates an ephemeral
# token per run; only set it for ad-hoc curls against the running
# production service.
SANDBOX_API_TOKEN=
