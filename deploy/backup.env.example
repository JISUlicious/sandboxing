# /etc/sandbox/backup.env — overrides for deploy/backup.sh.
# Copy to /etc/sandbox/backup.env on the host. Uncomment to override.
#
# Defaults:
#   BACKUP_ROOT=/var/backups/sandbox
#   BACKUP_KEEP_N=14
#   SANDBOX_DB=/var/lib/sandbox/sandbox.db
#   SANDBOX_AUDIT_DIR=/var/log/sandbox
#   SANDBOX_VOLUMES_MOUNT=/var/lib/sandbox-volumes
#   SANDBOX_FS_IMG=/var/lib/sandbox-fs.img
#   SANDBOX_ENV=/etc/sandbox/env
#   SANDBOX_SERVICE=sandbox-api.service

#BACKUP_ROOT=/srv/backup/sandbox
#BACKUP_KEEP_N=30
