# Sandbox Service — environment for the docker compose deployment.
# Copy to /etc/sandbox/env and edit the secrets:
#   sudo cp deploy/.env.compose.example /etc/sandbox/env
#   sudoedit /etc/sandbox/env
#   sudo chown root:root /etc/sandbox/env && sudo chmod 0640 /etc/sandbox/env
#
# The compose.yml passes /etc/sandbox/env into the control-plane
# container via env_file. Variables documented inline; SPEC + ARCH
# references in api/config.py.

# ----- Required secrets (no sane defaults) -----

# Bearer token for the bootstrap "default" tenant. Generate with:
#     openssl rand -hex 32
SANDBOX_API_TOKEN=__PUT_A_RANDOM_HEX_HERE__

# HMAC pepper for hashing tenant tokens (SPEC-405). Generate ONCE:
#     openssl rand -hex 32
# Rotating this invalidates every existing tenant token, so back this
# file up the moment you set it.
SANDBOX_TOKEN_PEPPER=__PUT_A_DIFFERENT_RANDOM_HEX_HERE__

# ----- Optional admin token (slice 12) -----

# Authorises the tenant-management API at /v1/tenants/*. Single-
# tenant deployments don't have to set this; admin endpoints return
# 503 admin_disabled when unset. Generate with:
#     openssl rand -hex 32
# Stored hashed under the synthetic `__admin__` tenant so the same
# revoke / rotation paths apply.
# SANDBOX_ADMIN_TOKEN=__PUT_A_THIRD_RANDOM_HEX_HERE__

# ----- Production-grade hardening (SPEC-401) -----

# Host UID that container UID 10001 maps to under userns-remap=default.
# `setup-host.sh --full` fills this in automatically; compute manually
# with (note +10001 — agent's container UID is 10001, NOT 10000):
#     awk -F: '$1=="dockremap"{print $2 + 10001}' /etc/subuid
SANDBOX_BIND_VOLUME_UID=110001

# ----- Runtime image variant (per-session sandboxes) -----
#
# Two runtime images ship with each release tag — see DEPLOY.md
# "Choosing the runtime image" for the bundled-package list.
#   - sandbox-runtime    (~150 MiB, default minimal)
#   - sandbox-runtime-ds (~5–7 GiB, data-science / ML / pptx-xlsx-docx)
#
# Leave SANDBOX_SANDBOX_IMAGE unset (commented out) to use the default
# minimal image. Set it explicitly to pick the variant. The control-
# plane and proxy images are not affected by this knob; only the per-
# session sandbox containers are.
#
# SANDBOX_SANDBOX_IMAGE=ghcr.io/jisulicious/sandbox-runtime-ds:latest

# ----- Image / version pin -----

# Resolves the ghcr.io tag for all three images in compose.yml. Pin to
# a specific release before going to prod so an upstream `latest`
# republish doesn't move under you.
#
# NOTE: `SANDBOX_VERSION` and `SANDBOX_VOLUME_BASE` are
# **compose-time substitution** variables — they fill the `${...}`
# slots in `compose.yml` (image tags, host bind paths). Compose does
# NOT read `/etc/sandbox/env` for substitution; it reads the calling
# shell env, a `.env` file next to compose.yml, or whatever you pass
# via `--env-file`. The simplest workflow is `docker compose
# --env-file /etc/sandbox/env up -d` — see DEPLOY.md "Customize the
# workspace volume path" for the why.
SANDBOX_VERSION=latest

# Workspace mount path on the host. Default matches the docs. To use
# a separate big disk you pre-mounted at `/data/sandbox-volumes`:
# uncomment + set, AND export the same variable before invoking
# setup-host.sh.
# IMPORTANT: pick this BEFORE the first session — docker volumes
# bake the absolute bind path into their metadata at create time.
# See DEPLOY.md "Customize the workspace volume path" for the
# migration procedure on a running host.
# SANDBOX_VOLUME_BASE=/var/lib/sandbox-volumes

# Loopback XFS image path (created by `setup-host.sh --with-xfs-quota`
# and used by deploy/backup.sh). Skip if you mounted a real XFS
# partition at SANDBOX_VOLUME_BASE.
# SANDBOX_FS_IMG=/var/lib/sandbox-fs.img

# ----- Optional: image namespace (forks) -----

# Where compose pulls the runtime/proxy/control-plane images from.
# Override if you fork the repo and publish to your own ghcr.io
# namespace; release.yml derives this automatically from the GitHub
# owner, but compose.yml needs the override at pull time.
# SANDBOX_IMAGE_NAMESPACE=ghcr.io/yourorg

# ----- Optional: network topology -----

# The sandbox_egress bridge subnet, the static proxy IP on it, and
# the proxy port. compose.yml + setup-host.sh + iptables-setup.sh
# all read these — set them ONCE here. Most operators leave defaults.
# SANDBOX_SUBNET=172.30.0.0/24
# PROXY_IP=172.30.0.2
# PROXY_PORT=3128

# ----- State paths (host-side, mounted into the container) -----

SANDBOX_DB_PATH=/var/lib/sandbox/sandbox.db
SANDBOX_AUDIT_LOG_PATH=/var/log/sandbox/audit.log

# ----- Optional knobs (defaults shown) -----
# SANDBOX_IDLE_STOP_MINUTES=15
# SANDBOX_HARD_DESTROY_HOURS=24
# SANDBOX_REAPER_INTERVAL_S=60
# SANDBOX_RESOURCE_SAMPLE_INTERVAL_S=10
# SANDBOX_TENANT_MAX_CONCURRENT=50
# SANDBOX_DEFAULT_VCPU=2
# SANDBOX_DEFAULT_MEMORY_MIB=2048
# SANDBOX_DEFAULT_WORKSPACE_MIB=1024
# SANDBOX_DEFAULT_PIDS=256
# SANDBOX_DEFAULT_NOFILE=1024

# ----- Slice 11/12 knobs (defaults usually fine) -----

# Idempotency-Key replay cache TTL (slice 11a). Stripe's reference
# is 24h; tune lower if storage pressure is a concern.
# SANDBOX_IDEMPOTENCY_TTL_S=86400

# Background-process tunables (slice 11b).
#   process_watcher_interval_s: pace lazy state refresh on
#     GET /processes calls (don't poll liveness more often than
#     this for a given row). Lower = more responsive state, more
#     docker-daemon traffic.
#   process_stop_grace_s: SIGTERM → wait → SIGKILL grace window
#     on DELETE /processes/{pid}.
#   tenant_max_processes: ceiling on Limits.max_processes (8
#     default in Limits; raise per-session up to this max).
# SANDBOX_PROCESS_WATCHER_INTERVAL_S=2.0
# SANDBOX_PROCESS_STOP_GRACE_S=10
# SANDBOX_TENANT_MAX_PROCESSES=32

# ----- TLS-readiness (slice 8e) -----
# Enable ONLY when running behind a trusted reverse proxy (Caddy /
# nginx) that sets X-Forwarded-* headers. Spoofable otherwise.
# SANDBOX_TRUST_PROXY_HEADERS=true

# ----- Do NOT set in compose path -----
# SANDBOX_DEV_MODE     <- production posture; leave unset
# SANDBOX_BIND_HOST    <- compose.yml sets this to 0.0.0.0 internally
# SANDBOX_BIND_PORT    <- compose.yml + ports mapping handle this
# SANDBOX_NETWORK_NAME             <- pinned in compose.yml
# SANDBOX_EGRESS_PROXY_URL         <- pinned in compose.yml
# SANDBOX_SANDBOX_IMAGE            <- operator-overridable (see "Runtime image variant" above)
# SANDBOX_QUOTA_SETUP_CMD          <- pinned in compose.yml
# SANDBOX_QUOTA_TEARDOWN_CMD       <- pinned in compose.yml
# SANDBOX_QUOTA_VOLUME_BASE        <- pinned in compose.yml
