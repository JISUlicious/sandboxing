#!/usr/bin/env bash
# Wrapper invoked by the control plane for SPEC-302 quota setup.
# Delegates to /usr/local/bin/sandbox-quota-helper (root-owned, single
# locked-down sudoers entry — see deploy/sandbox-quota-helper.sh).
#
# Env vars supplied by the control plane:
#   SESSION_ID, TENANT_ID, VOLUME_NAME, VOLUME_PATH, VOLUME_BASE,
#   WORKSPACE_MIB
# (TENANT_ID + VOLUME_NAME are unused by the helper today but passed
# through for forward-compat.)

set -euo pipefail
exec sudo -n /usr/local/bin/sandbox-quota-helper setup
